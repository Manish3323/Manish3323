---
import Card from "../components/Card.astro";
import MySiteLayout from "../layouts/Layout.astro";

type Experience = {
  title: string;
  company: string;
  description: string;
  role: string;
  tags: string[];
  favourite?: boolean;
  learnings?: string[];
  href?: string;
  isPrivate: boolean;
};

const experiences: Experience[] = [
  {
    title: "Marketing & Retail Fraud Detection Products",
    company: "TechVerito India",
    role: "Lead Consultant - Application Developer",
    tags: [
      "Spring Boot",
      "React",
      "Typescript",
      "Next.js",
      "PostgreSQL",
      "Docker",
      "Kubernetes",
      "CI/CD",
    ],
    description: `Led a team of 8 developers at TechVerito building a Spring-based microservices backend and React-based frontend for a marketing firm and a retail fraud detection product. Drove architectural decisions, enforced code quality standards, and evaluated new technologies to boost product capabilities.`,
    learnings: [
      "Leading a team of 8 developers and achieving sprint goals",
      "Enforcing code quality, scalability, and maintainability standards",
      "Assessing and recommending new technologies for product capabilities",
      "Balancing technical leadership with hands-on delivery",
    ],
    isPrivate: true,
  },
  {
    title: "Developer Portal/Data discovery Platform",
    company: "Thoughtworks India",
    role: "Senior Consultant - Application Developer",
    tags: [
      "Backstage",
      "Java",
      "Data Mesh",
      "Typescript",
      "Python",
      "React",
      "Azure Kubernetes",
      "Kafka",
      "ElasticSearch",
      "Apache Arrow Flight",
      "Nginx",
      "Mountebank",
    ],
    description: `Built a Data Mesh platform for a global investment bank using Backstage as a discovery tool for isolated business pods. Integrated Kafka, deployed ElasticSearch, implemented Apache Arrow Flight server, used Mountebank for local development mocking, and configured Nginx ingress for Kubernetes. Delivered talks on Backstage and made architectural recommendations including ES modules and environment-agnostic images.`,
    learnings: [
      "Involved in discovery/inception of the greenfield project",
      "Delivering small chunks in terms of prototyping to gain client's trust",
      "Leading team and onboarding new members",
      "Expectation management is crucial",
      "Architectural recommendations require clear communication and data",
      "Higher velocity leads to degradation of code quality, at times this is acceptable too.",
    ],
    isPrivate: true,
  },
  {
    title: "Engineering for Research: Thirty Meter Telescope",
    company: "Thoughtworks India",
    role: "Consultant - Application Developer",
    favourite: true,
    description: `Multi-year project building fundamental software components for the Thirty Meter Telescope (TMT). Developed critical software for astronomical observations in Scala, Kotlin, and Akka. Led frontend stack decisions, built TypeScript-based npm libraries, improved DSLs for scripting, and built monitoring dashboards. Wrote technical and user documentation with Paradox. The telescope is set for first light in 2030 from Mauna Kea Observatory, Hawaii. 🤞🏻`,
    isPrivate: false,
    tags: [
      "Typescript",
      "React",
      "React-query",
      "Scala",
      "Akka",
      "Kotlin",
      "Concurrency",
      "Testing Pyramid",
      "DSL",
      "SBT",
      "Vite",
    ],
    learnings: [
      "Thought process while authoring and publishing npm libraries",
      "Intricacies of API design and interface-based programming",
      "What it takes to build a VSCode plugin",
      "Integrating JVM class files at runtime",
      "Building Domain Specific Languages for scripting",
      "Experienced what pair programming truly is — no way back now",
      "Presenting demos and prototyping to stakeholders",
      "The joy of working with strongly typed languages like Scala and TypeScript",
      "Frontend stack leadership and architectural decision-making",
    ],
    href: "https://github.com/tmtsoftware/esw",
  },
  {
    title: "VScode plugin for testing tool",
    company: "Open Source",
    role: "Javascript developer",
    tags: ["VScode", "Typescript", "Testing", "@web/test-runner"],
    learnings: [
      "what all it takes to create a plugin for IDE",
      "Understand plugin architecture of the vscode",
      "Limitations of electron based desktop apps, since it supports commonjs format",
    ],
    description: `
      We were using @web/test-runner in TMT project as a testing framework instead of jest because of it's lack of support for ES Modules.
      @web/test-runner didn't had much extensions as it was fairly new. so we decided to create a VSCode plugin which will help dev's to run/debug tests using Code actions.
    `,
    isPrivate: false,
    href: "https://marketplace.visualstudio.com/items?itemName=manishgowardipe.test-runner",
  },
  {
    title: "Search optimization based on elastic search.",
    company: "Thoughtworks India",
    role: "Software Developer",
    learnings: [
      "How does search engines mechanism work",
      "what is reverse indexing, how does tokenizing the search document help in returning results",
      "How to evolve API which are already in production & being consumed by other services"
    ],
    description: `
      Enchancing the user experience for a multi tenant retail client by providing relevent search results 
      using different relevency parameters in the search index of the products.`,
    tags: [
      "Elastic search",
      "retail",
      "indexing",
      "Point of sale",
      "Java",
      "Postgres",
      "Rest API designing",
    ],
    isPrivate: true,
  },
  {
    title: "Healthcare Networking Platform",
    company: "PlexusMD (now Medflix)",
    role: "Software Developer",
    tags: ["React Native", "Node", "Loopback", "Mysql"],
    learnings: [
      "Experienced the Joy / Horrors of startup culture",
      "Never make long term decisions in rush",
      "Flat hierarchies are very nice to get things done quickly",
      "Hiring process in the industry is in very bad shape in india :(",
    ],
    description: `
    A Healthcare Network mobile application written in React Native backed by Node.js Loopback framework.
    Wrote Database related queries and scripts to automated daily routines like backing up and writing logs at regular intervals to get better insight of the product.
    `,
    isPrivate: true,
  },
];
---

<MySiteLayout title="Experience">
  <ul>
    {
      experiences.map((exp) => (
        <details>
          <summary>
            {exp.role} @ {exp.company}
          </summary>
          <Card {...exp} />
        </details>
      ))
    }
  </ul>
</MySiteLayout>
